{
  "name": "studydiff-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.nickjlamb/studydiff",
  "description": "Explain why two scientific papers disagree. Extracts each study's design, isolates the methodological differences that likely drive conflicting conclusions, and grounds every claim in the source text. MCP server + web app + CLI.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://studydiff.pharmatools.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickjlamb/studydiff.git"
  },
  "bugs": {
    "url": "https://github.com/nickjlamb/studydiff/issues"
  },
  "author": "Nick Lamb",
  "bin": {
    "studydiff": "src/cli.mjs",
    "studydiff-mcp": "src/mcp.mjs"
  },
  "files": [
    "src/",
    "fixtures/",
    "eval/",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/server.mjs",
    "serve": "node src/server.mjs",
    "demo": "node src/demo.mjs",
    "cli": "node src/cli.mjs",
    "mcp": "node src/mcp.mjs",
    "eval": "node eval/score.mjs",
    "eval:fetch": "node eval/fetch.mjs",
    "eval:variance": "node eval/variance.mjs",
    "eval:diagnose": "node eval/diagnose.mjs",
    "eval:selftest": "node eval/selftest.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pharmatools/opengate": "^0.9.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "life-sciences",
    "literature",
    "evidence",
    "contradiction",
    "reproducibility",
    "grounding",
    "claude",
    "pubmed"
  ]
}
